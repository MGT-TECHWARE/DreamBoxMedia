# Optional: URLs for large videos (required for Cloudflare Pages when files exceed 25MB — host on R2 or another CDN).
# Leave unset for local dev (uses files from public/ if present).
#
# If videos don't appear on the live site:
# 1. Run: npm run r2-cors   (allows your Pages site to load R2 videos)
# 2. Set these variables so the build can write them into config.json:
#    Cloudflare Dashboard → Pages → dreambox-media → Settings →
#    Environment variables → Add for "Build" (not only Production).
#    Then redeploy so the new build picks them up.

# Hero + Drone Services section
# VITE_DRONE_LOOP_VIDEO_URL=https://your-bucket.example.com/drone-loop.mp4

# Commercials & High-End section
# VITE_COMMERCIALS_VIDEO_URL=https://your-bucket.example.com/commercials-bg.mov

# Videography section
# VITE_VIDEOGRAPHY_VIDEO_URL=https://your-bucket.example.com/videography-bg.mov

# Strategic Video Marketing section
# VITE_STRATEGIC_VIDEO_MARKETING_VIDEO_URL=https://your-bucket.example.com/strategic-video-marketing-bg.mov

# Documentary Storytelling section
# VITE_DOCUMENTARY_VIDEO_URL=https://your-bucket.example.com/documentary-bg.mov

# Brand Video Production section
# VITE_BRAND_VIDEO_VIDEO_URL=https://your-bucket.example.com/brand-video-bg.mp4

# Hype Videos & Recaps section
# VITE_HYPE_RECAP_VIDEO_URL=https://your-bucket.example.com/hype-recap-bg.mp4

# Corporate Events section
# VITE_CORPORATE_EVENTS_VIDEO_URL=https://your-bucket.example.com/corporate-events-bg.mov

# Cinematography section
# VITE_CINEMATOGRAPHY_VIDEO_URL=https://your-bucket.example.com/cinematography-bg.mov

# R2 S3 API upload (npm run upload-r2) — create token at R2 → Manage R2 API Tokens
# R2_ACCESS_KEY_ID=your_access_key_id
# R2_SECRET_ACCESS_KEY=your_secret_access_key
# R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# R2_BUCKET=dreambox-media-assets
